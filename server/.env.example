# ============================================================
# AgriExchange — Configuration serveur
# Copiez ce fichier en .env et remplissez les valeurs reelles
# NE JAMAIS committer le .env avec de vrais secrets
# ============================================================

# --- Base de donnees ---
# Fournisseur actif : 'mysql' | 'mongo' | 'postgres'
DATABASE_PROVIDER=mysql

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=agriexchange
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_POOL_SIZE=25

# MongoDB (optionnel — backup / migration)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/agriexchange

# --- Serveur ---
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# URL publiques (production uniquement)
# CLIENT_URL=https://vivrimarket.com
# SERVER_URL=https://api.vivrimarket.com

# --- Authentification JWT ---
# Utilisez une valeur aleatoire forte en production (min 32 caracteres)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET
REFRESH_SECRET=CHANGE_ME_ANOTHER_STRONG_SECRET
JWT_EXPIRE=7d
REFRESH_EXPIRE=30d

# --- Cloudinary (stockage images) ---
CLD_CLOUD=your_cloudinary_cloud_name
CLD_KEY=your_cloudinary_api_key
CLD_SECRET=your_cloudinary_api_secret

# --- CinetPay (paiements) ---
CINETPAY_APIKEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id

# --- WhatsApp (notifications) ---
WHATSAPP_ENABLED=false
